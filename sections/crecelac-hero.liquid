<div class="crecelac-hero" id="crecelac-hero-{{ section.id }}">
  <div class="container">
    <div class="crecelac-hero__grid">
      <div class="crecelac-hero__content">
        {% if section.settings.heading != blank %}
        <h1 class="crecelac-hero__heading">{% render 'multilang' with section.settings.heading %}</h1>
        {% endif %}

        {% if section.settings.subheading != blank %}
        <div class="crecelac-hero__subheading">{% render 'multilang' with section.settings.subheading %}</div>
        {% endif %}

        <div class="crecelac-hero__buttons">
          {% if section.settings.button_1_text != blank %}
          <a href="{{ section.settings.button_1_link }}" class="crecelac-btn crecelac-btn--primary">
            {% render 'multilang' with section.settings.button_1_text %}
          </a>
          {% endif %}

          {% if section.settings.button_2_text != blank %}
          <a href="{{ section.settings.button_2_link }}" class="crecelac-btn crecelac-btn--outline">
            {% render 'multilang' with section.settings.button_2_text %}
          </a>
          {% endif %}
        </div>

        <ul class="crecelac-hero__trust">
          {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
          <li {{ block.shopify_attributes }}>
            <span class="crecelac-hero__trust-icon">{% render 'icon-crecelac', icon: block.settings.icon %}</span>
            <span>{% render 'multilang' with block.settings.text %}</span>
          </li>
          {% endfor %}
          {% else %}
          <li>
            <span class="crecelac-hero__trust-icon">{% render 'icon-crecelac', icon: 'check' %}</span>
            <span>Ingredientes de alta calidad</span>
          </li>
          <li>
            <span class="crecelac-hero__trust-icon">{% render 'icon-crecelac', icon: 'shield' %}</span>
            <span>Respaldo cientifico</span>
          </li>
          <li>
            <span class="crecelac-hero__trust-icon">{% render 'icon-crecelac', icon: 'family' %}</span>
            <span>Hecho en Mexico con amor</span>
          </li>
          {% endif %}
        </ul>
      </div>

      <div class="crecelac-hero__media">
        {% if section.settings.image != blank %}
        {%- assign img_url = section.settings.image | img_url: '1200x' -%}
        <img data-src="{{ img_url }}" src="{{ img_url }}" alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}" class="lazyautosizes lazyloaded" data-sizes="auto">
        {% else %}
        <div class="not_img">1200 x 900px</div>
        {% endif %}

        {% if section.settings.show_badge and section.settings.badge_title != blank %}
        <div class="crecelac-hero__badge">
          <span class="crecelac-hero__badge-icon">{% render 'icon-crecelac', icon: 'points' %}</span>
          <div>
            <strong>{% render 'multilang' with section.settings.badge_title %}</strong>
            {% if section.settings.badge_subtitle != blank %}
            <span>{% render 'multilang' with section.settings.badge_subtitle %}</span>
            {% endif %}
          </div>
        </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<style>
  #crecelac-hero-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: 56px 0;
    overflow: hidden;
  }

  #crecelac-hero-{{ section.id }} .crecelac-hero__grid {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  #crecelac-hero-{{ section.id }} .crecelac-hero__content {
    flex: 0 0 36%;
    max-width: 36%;
  }

  #crecelac-hero-{{ section.id }} .crecelac-hero__heading {
    font-size: 42px;
    line-height: 1.15;
    font-weight: 700;
    color: {{ section.settings.heading_color }};
    margin: 0 0 18px;
  }

  #crecelac-hero-{{ section.id }} .crecelac-hero__subheading {
    font-size: 16px;
    line-height: 1.6;
    color: {{ section.settings.text_color }};
    margin-bottom: 28px;
  }

  #crecelac-hero-{{ section.id }} .crecelac-hero__buttons {
    display: flex;
    gap: 16px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }

  #crecelac-hero-{{ section.id }} .crecelac-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    border-radius: 4px;
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    border: 1px solid {{ section.settings.accent_color }};
    transition: all .2s ease;
  }

  #crecelac-hero-{{ section.id }} .crecelac-btn--primary {
    background-color: {{ section.settings.accent_color }};
    color: {{ section.settings.accent_text_color }};
  }

  #crecelac-hero-{{ section.id }} .crecelac-btn--primary:hover {
    opacity: .88;
  }

  #crecelac-hero-{{ section.id }} .crecelac-btn--outline {
    background-color: transparent;
    color: {{ section.settings.heading_color }};
    border-color: {{ section.settings.heading_color }};
  }

  #crecelac-hero-{{ section.id }} .crecelac-btn--outline:hover {
    background-color: {{ section.settings.heading_color }};
    color: #fff;
  }

  #crecelac-hero-{{ section.id }} .crecelac-hero__trust {
    display: flex;
    flex-wrap: nowrap;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #crecelac-hero-{{ section.id }} .crecelac-hero__trust li {
    display: flex;
    align-items: center;
    gap: 6px;
    flex: 1 1 0;
    min-width: 0;
    font-size: 12px;
    line-height: 1.3;
    color: {{ section.settings.text_color }};
  }

  #crecelac-hero-{{ section.id }} .crecelac-hero__trust-icon {
    display: inline-flex;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    color: {{ section.settings.accent_color }};
  }

  #crecelac-hero-{{ section.id }} .crecelac-hero__media {
    position: relative;
    flex: 1;
  }

  #crecelac-hero-{{ section.id }} .crecelac-hero__media img {
    width: 100%;
    border-radius: 12px;
    display: block;
  }

  #crecelac-hero-{{ section.id }} .crecelac-hero__badge {
    position: absolute;
    right: 24px;
    bottom: 24px;
    background: #fff;
    border-radius: 10px;
    box-shadow: 0 12px 30px rgba(0,0,0,.15);
    padding: 14px 18px;
    display: flex;
    align-items: center;
    gap: 12px;
    max-width: 240px;
  }

  #crecelac-hero-{{ section.id }} .crecelac-hero__badge-icon {
    width: 30px;
    height: 30px;
    flex-shrink: 0;
    color: {{ section.settings.accent_color }};
  }

  #crecelac-hero-{{ section.id }} .crecelac-hero__badge div {
    display: flex;
    flex-direction: column;
    font-size: 12px;
    color: #666;
  }

  #crecelac-hero-{{ section.id }} .crecelac-hero__badge strong {
    font-size: 14px;
    color: {{ section.settings.heading_color }};
  }

  @media (max-width: 991px) {
    #crecelac-hero-{{ section.id }} .crecelac-hero__grid {
      flex-direction: column;
    }

    #crecelac-hero-{{ section.id }} .crecelac-hero__content {
      max-width: 100%;
      flex: 1;
      text-align: center;
    }

    #crecelac-hero-{{ section.id }} .crecelac-hero__buttons,
    #crecelac-hero-{{ section.id }} .crecelac-hero__trust {
      justify-content: center;
    }

    #crecelac-hero-{{ section.id }} .crecelac-hero__heading {
      font-size: 30px;
    }

    #crecelac-hero-{{ section.id }} .crecelac-hero__badge {
      position: static;
      margin-top: 16px;
      max-width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "Crecelac: Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titulo",
      "default": "Nutricion completa en cada sorbo."
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subtitulo",
      "default": "<p>Una bebida lista para consumir con proteina, vitaminas, minerales y otros nutrientes esenciales para toda la familia.</p>"
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Texto boton primario",
      "default": "Comprar ahora"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Enlace boton primario"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Texto boton secundario",
      "default": "Conoce mas"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Enlace boton secundario"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagen"
    },
    {
      "type": "header",
      "content": "Tarjeta flotante"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Mostrar tarjeta flotante",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_title",
      "label": "Titulo tarjeta",
      "default": "+2,500 familias"
    },
    {
      "type": "text",
      "id": "badge_subtitle",
      "label": "Subtitulo tarjeta",
      "default": "confian en Crecelac"
    },
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fondo de seccion",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color del titulo",
      "default": "#232323"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color de texto",
      "default": "#4a4a4a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de acento",
      "default": "#c70000"
    },
    {
      "type": "color",
      "id": "accent_text_color",
      "label": "Color de texto sobre acento",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Insignia de confianza",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icono",
          "options": [
            { "value": "check", "label": "Check" },
            { "value": "shield", "label": "Escudo" },
            { "value": "family", "label": "Familia" },
            { "value": "clock", "label": "Reloj" },
            { "value": "truck", "label": "Camion" },
            { "value": "pause", "label": "Pausa" },
            { "value": "points", "label": "Puntos / estrella" },
            { "value": "protein", "label": "Proteina" },
            { "value": "vitamins", "label": "Vitaminas" },
            { "value": "prebiotics", "label": "Prebioticos" },
            { "value": "gluten-free", "label": "Libre de gluten" },
            { "value": "lactose-free", "label": "Sin lactosa" },
            { "value": "ready-to-drink", "label": "Listo para beber" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texto",
          "default": "Ingredientes de alta calidad"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Crecelac: Hero",
      "category": "Crecelac",
      "blocks": [
        { "type": "trust_badge", "settings": { "icon": "check", "text": "Ingredientes de alta calidad" } },
        { "type": "trust_badge", "settings": { "icon": "shield", "text": "Respaldo cientifico" } },
        { "type": "trust_badge", "settings": { "icon": "family", "text": "Hecho en Mexico con amor" } }
      ]
    }
  ]
}
{% endschema %}
