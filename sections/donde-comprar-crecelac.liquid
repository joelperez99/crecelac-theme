<style>

*{
    box-sizing:border-box;
}

.crecelac{
    max-width:1400px;
    margin:auto;
    padding:20px;
    font-family:Arial,Helvetica,sans-serif;
}

.crecelac h2{
    text-align:center;
    margin-bottom:30px;
}

/* =======================
      ESCRITORIO
======================= */

.desktop{
    display:grid;
    grid-template-columns:220px 1fr 220px;
    gap:25px;
    align-items:center;
}

.columna{
    display:flex;
    flex-direction:column;
    justify-content:space-between;
    height:760px;
}

.columna img{
    width:100%;
    height:auto;
    object-fit:contain;
}

.anaquel img{
    width:100%;
    display:block;
}

/* =======================
      MÓVIL
======================= */

.mobile{
    display:none;
}

.mobile .anaquel img{
    width:100%;
}

.mobile-grid{

    display:grid;

    grid-template-columns:repeat(2,1fr);

    gap:25px;

    margin-top:35px;

}

.mobile-grid img{

    width:100%;

    max-height:70px;

    object-fit:contain;

}

/* =======================
      RESPONSIVE
======================= */

@media(max-width:768px){

.desktop{
display:none;
}

.mobile{
display:block;
}

}

</style>

