{% comment %}
  Renders a small line-style SVG icon used across the Crecelac homepage sections.
  Usage: {% render 'icon-crecelac', icon: 'protein' %}
  Available icons: protein, vitamins, prebiotics, gluten-free, lactose-free, ready-to-drink,
  clock, shield, truck, pause, points, family, check, cross, quote
{% endcomment %}
<svg class="icon-crecelac icon-crecelac--{{ icon }}" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:100%;fill:none;stroke:currentColor;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;">
  {%- case icon -%}
    {%- when 'protein' -%}
      <path d="M24 6c-5 0-8 4-8 8 0 2 1 3 1 5 0 8-5 11-5 17a12 12 0 0 0 24 0c0-6-5-9-5-17 0-2 1-3 1-5 0-4-3-8-8-8Z"/>
      <path d="M18 26h12"/>
    {%- when 'vitamins' -%}
      <circle cx="24" cy="24" r="15"/>
      <path d="M24 15v18M15 24h18M18.5 18.5l11 11M29.5 18.5l-11 11"/>
    {%- when 'prebiotics' -%}
      <path d="M24 8c6 3 14 3 14 3s0 15-14 29C10 26 10 11 10 11s8 0 14-3Z"/>
      <path d="M24 18v18M18 24c2 2 4 2 6 0M24 24c2 2 4 2 6 0"/>
    {%- when 'gluten-free' -%}
      <path d="M24 6c3 4 3 7 0 10-3-3-3-6 0-10Z"/>
      <path d="M24 16v26M16 24c3-3 6-3 8 0M24 24c2-3 5-3 8 0M14 34c4-3 7-3 10 0M24 34c3-3 6-3 10 0"/>
      <path d="M9 40 39 10" stroke-width="2.5"/>
    {%- when 'lactose-free' -%}
      <path d="M18 6h12v6l3 5v23a2 2 0 0 1-2 2H17a2 2 0 0 1-2-2V17l3-5Z"/>
      <path d="M18 6h12M15 22h18"/>
      <path d="M9 40 39 8" stroke-width="2.5"/>
    {%- when 'ready-to-drink' -%}
      <path d="M15 8h18M17 8l1 8h12l1-8"/>
      <path d="M18 16l-2 22a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2l-2-22"/>
      <path d="M17 27h14"/>
    {%- when 'clock' -%}
      <circle cx="24" cy="24" r="16"/>
      <path d="M24 15v9l7 4"/>
    {%- when 'shield' -%}
      <path d="M24 6l14 5v11c0 10-6 16-14 20-8-4-14-10-14-20V11l14-5Z"/>
      <path d="M17 24l5 5 9-10"/>
    {%- when 'truck' -%}
      <path d="M4 14h22v18H4z"/>
      <path d="M26 20h8l6 6v6h-14z"/>
      <circle cx="12" cy="34" r="3"/>
      <circle cx="34" cy="34" r="3"/>
    {%- when 'pause' -%}
      <circle cx="24" cy="24" r="16"/>
      <path d="M20 17v14M28 17v14"/>
    {%- when 'points' -%}
      <path d="M24 6l4.6 9.5 10.4 1.5-7.5 7.4 1.8 10.4L24 29.8l-9.3 4.9 1.8-10.4-7.5-7.4 10.4-1.5Z"/>
    {%- when 'family' -%}
      <circle cx="15" cy="14" r="4"/>
      <circle cx="33" cy="14" r="4"/>
      <circle cx="24" cy="24" r="4"/>
      <path d="M6 40c0-6 4-10 9-10s9 4 9 10M24 40c0-5 3.5-9 8-9s8 4 8 9"/>
    {%- when 'check' -%}
      <circle cx="24" cy="24" r="16"/>
      <path d="M17 24l5 5 9-10"/>
    {%- when 'cross' -%}
      <circle cx="24" cy="24" r="16"/>
      <path d="M18 18l12 12M30 18l-12 12"/>
    {%- when 'quote' -%}
      <path d="M10 26c0-8 5-13 12-14v5c-4 1-6 4-6 7h6v11H10v-9Z"/>
      <path d="M24 26c0-8 5-13 12-14v5c-4 1-6 4-6 7h6v11H24v-9Z"/>
  {%- endcase -%}
</svg>
